{
  "name": "security-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The auth service's own face — and the specs' third entry point: cucumber-js + Playwright drive the same Gherkin the JVM runners do, through this React UI.",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "e2e": "cucumber-js --config e2e/cucumber.mjs",
    "e2e:full": "./run-e2e.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.50.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.7"
  }
}
